@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<html lang="en">
<head>


    <!-- Includes all JS & CSS for the JavaScript Data Grid -->
    <script src="https://cdn.jsdelivr.net/npm/ag-grid-community/dist/ag-grid-community.min.js"></script>

</head>
<body>
    <!-- Your Data Grid container -->
    <div id="myGrid"  style="height: 500px; width: 100%;"></div>



    <script>
        const gridOptions = {
            columnDefs: [
                { field: "purchId", headerName: "ID" },
                { field: "purchName", headerName: "Nombre" },
                { field: "orderAccount", headerName: "Cuenta" },
                { field: "currencyCode", headerName: "Moneda" },
                { field: "dlvMode", headerName: "Modo Entrega" },
                { field: "purchStatus", headerName: "Estado" },
                { field: "createdDateTime", headerName: "Fecha Creación" }
            ],
            defaultColDef: {
                flex: 1,
                sortable: true,
                filter: true,
                resizable: true
            },
            pagination: true,
            paginationPageSize: 10,
            paginationAutoPageSize: false //  Mantén tamaño fijo
        };

        const gridDiv = document.querySelector("#myGrid");
        const gridApi = agGrid.createGrid(gridDiv, gridOptions);

        //Traer TODOS los registros y dejar que AG Grid pagine
        fetch('/Index?handler=Autos')
            .then(response => response.json())
            .then(result => {
                gridApi.setGridOption('rowData', result.data);
            });

        function loadLines(purchId) {
            fetch(`/PurchLine?handler=Lines&purchId=${encodeURIComponent(purchId)}`)
                .then(response => response.json())
                .then(result => {
                    // Aquí puedes mostrar el detalle en otra AG Grid o modal
                    console.log(result.data);
                });
        }

    </script>




</body>
</html>